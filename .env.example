# ============================================================
# Company Slide Builder - 環境変数設定
# ============================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# GitHub Actions で使う場合は GitHub Secrets に設定してください:
#   Settings > Secrets and variables > Actions
# ============================================================

# --- メール通知（Gmail SMTP） ---
# Googleアプリパスワード（16文字）を設定
# 取得方法: Googleアカウント > セキュリティ > 2段階認証 > アプリパスワード
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_TO=your-email@gmail.com
MAIL_FROM=your-email@gmail.com

# --- Discord通知 ---
# DiscordチャンネルのWebhook URL
# 取得方法: Discord > チャンネル設定 > 連携サービス > ウェブフック
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx
